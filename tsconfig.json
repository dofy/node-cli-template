{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "target": "es2022",
    "lib": ["es2023"],
    "module": "node16",
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
